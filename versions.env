# =============================================================================
# Build Version Configuration — Single Source of Truth
# =============================================================================
# Referenced by:
#   - mise.toml               (via _.file, for local development)
#   - .devcontainer/Dockerfile (sourced during image build)
#   - .github/workflows/build.yml (loaded into $GITHUB_ENV)
#
# To update a version, change it HERE and everything else follows.
# =============================================================================

# Rust toolchain version — should match rust-toolchain.toml channel.
RUST_VERSION=1.85.0

# Cross-compilation tool (https://github.com/rust-embedded/cross)
CROSS_VERSION=0.2.5

# Android NDK linker configuration (API level 21 = Android 5.0 Lollipop)
CARGO_TARGET_AARCH64_LINUX_ANDROID_LINKER=aarch64-linux-android21-clang
CARGO_TARGET_ARMV7_LINUX_ANDROIDEABI_LINKER=armv7a-linux-androideabi21-clang
CARGO_TARGET_I686_LINUX_ANDROID_LINKER=i686-linux-android21-clang
CARGO_TARGET_X86_64_LINUX_ANDROID_LINKER=x86_64-linux-android21-clang

# Android SDK API level for cmake (used by cross Docker images via /opt/toolchain.cmake).
# Must match the API level in the linker names above.
# Also used in build.yml to construct CROSS_CMAKE_OBJECT_FLAGS with the correct
# clang --target triple (the cross Docker images bake in triples without an API
# level suffix, which would cause __ANDROID_API_FUTURE__).
CROSS_ANDROID_SDK=21
