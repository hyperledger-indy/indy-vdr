{
  "name": "@hyperledger/indy-vdr-wrapper-javascript",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperledger-indy/indy-vdr",
    "directory": "wrappers/javascript"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "style:check": "biome check --unsafe .",
    "style:fix": "pnpm style:check --write",
    "types:check": "pnpm -r types:check",
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "test": "vitest",
    "test:local-build": "LIB_INDY_VDR_PATH=../../../target/release pnpm test",
    "set-version": "lerna version --exact --no-git-tag-version --no-push --yes"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "rimraf": "catalog:",
    "typescript": "catalog:",
    "vite-tsconfig-paths": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.29.2"
}
